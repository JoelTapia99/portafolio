---
import {HOST_URL} from "../../constants/app.constants.ts";
import {METADATA} from "../../constants/metadata.constants.ts";
import Navbar from "../../components/Navbar.astro";
import Hero from '../../components/Hero.astro';
import About from "../../components/About.astro";
import Skills from "../../components/Skills.astro";
import Timeline from "../../components/Timeline.astro";
import Projects from '../../components/Projects.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import {getLangFromUrl, useTranslations} from "../../utils/lang.utils.ts";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset='UTF-8'/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel='icon' type='image/svg+xml' href='/favicon.png'/>
    <meta name='generator' content={Astro.generator}/>
    <meta name="description" content={t('meta.description')} />
    <!-- Open Graph -->
    <meta property='og:title' content={t('meta.title')}/>
    <meta property='og:description' content={t('meta.description')}/>
    <meta property='og:url' content={`${HOST_URL}/en`}/>
    <meta property='og:type' content={METADATA.type}/>
    <meta property='og:site_name' content={METADATA.siteName}/>
    <meta property='og:locale' content={t('meta.locale')}/>
    <meta property='og:image' content={METADATA.image}/>
    <meta property='og:image:alt' content={t('meta.imageAlt')}/>
    <!-- Twitter -->
    <meta name="twitter:card" content={METADATA.twitterCard} />
    <meta name="twitter:title" content={t('meta.title')} />
    <meta name="twitter:description" content={t('meta.description')} />
    <meta name="twitter:image" content={METADATA.image} />
    <meta name="twitter:image:alt" content={t('meta.imageAlt')} />
    <!-- canonical -->
    <link rel='canonical' href={`${HOST_URL}/en`}/>

    <title>{t('meta.title')}</title>
</head>
<body>
<main>
    <Navbar lang={lang}/>
    <Hero lang={lang}/>
    <hr/>
    <About lang={lang}/>
    <hr/>
    <Skills lang={lang}/>
    <hr/>
    <Timeline lang={lang}/>
    <hr/>
    <Contact lang={lang}/>
    <hr/>
    <Footer/>
</main>
</body>
</html>

<style is:global>
    :root {
        --background: oklch(0.13 0.02 260);
        --foreground: oklch(0.95 0 0);
        --card: oklch(0.16 0.02 260);
        --card-foreground: oklch(0.95 0 0);
        --popover: oklch(0.16 0.02 260);
        --popover-foreground: oklch(0.95 0 0);
        --primary: oklch(0.65 0.2 180);
        --primary-foreground: oklch(0.13 0.02 260);
        --secondary: oklch(0.22 0.02 260);
        --secondary-foreground: oklch(0.85 0 0);
        --muted: oklch(0.22 0.02 260);
        --muted-foreground: oklch(0.65 0 0);
        --accent: oklch(0.65 0.2 180);
        --accent-foreground: oklch(0.13 0.02 260);
        --destructive: oklch(0.577 0.245 27.325);
        --destructive-foreground: oklch(0.95 0 0);
        --border: oklch(0.28 0.02 260);
        --input: oklch(0.22 0.02 260);
        --ring: oklch(0.65 0.2 180);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        border-color: var(--border);
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        min-height: 100vh;
        background: var(--background);
        color: var(--foreground);
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }

    main {
        min-height: 100vh;
    }

    input,
    textarea,
    button,
    select {
        font: inherit;
    }

    a {
        color: inherit;
        text-decoration: inherit;
    }

    img,
    picture,
    svg {
        display: block;
        max-width: 100%;
    }
</style>

