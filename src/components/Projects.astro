---
import {CUSTOM_IMGS} from '../constants/custom-imgs.constants.ts';

const projects = [
  {
    title: "E-Commerce Platform",
    description:
      "Plataforma completa de comercio electronico con carrito, pagos con Stripe, dashboard de admin y gestion de inventario en tiempo real.",
    image: "/placeholder-project-1.jpg",
    tags: ["Next.js", "Stripe", "PostgreSQL", "Tailwind"],
    liveUrl: "https://example.com",
    githubUrl: "https://github.com",
    featured: true,
  },
  {
    title: "Task Management App",
    description:
      "Aplicacion de gestion de tareas con drag-and-drop, colaboracion en tiempo real, notificaciones y reportes de productividad.",
    image: "/placeholder-project-2.jpg",
    tags: ["React", "Node.js", "Socket.io", "MongoDB"],
    liveUrl: "https://example.com",
    githubUrl: "https://github.com",
    featured: true,
  },
  {
    title: "AI Content Generator",
    description:
      "Herramienta de generacion de contenido con IA. Integra OpenAI GPT-4 para crear articulos, posts y copy de marketing.",
    image: "/placeholder-project-3.jpg",
    tags: ["Next.js", "OpenAI", "Vercel AI", "Supabase"],
    liveUrl: "https://example.com",
    githubUrl: "https://github.com",
    featured: true,
  },
  {
    title: "Real Estate Portal",
    description:
      "Portal inmobiliario con busqueda avanzada, mapas interactivos, tours virtuales 360 y sistema de citas.",
    image: "/placeholder-project-4.jpg",
    tags: ["Vue.js", "Express", "MapBox", "Redis"],
    liveUrl: "https://example.com",
    githubUrl: "https://github.com",
    featured: false,
  },
  {
    title: "Fitness Tracker",
    description:
      "App de seguimiento fitness con planes de entrenamiento personalizados, graficas de progreso y sincronizacion con wearables.",
    image: "/placeholder-project-5.jpg",
    tags: ["React Native", "Firebase", "Chart.js"],
    liveUrl: "https://example.com",
    githubUrl: "https://github.com",
    featured: false,
  },
  {
    title: "Developer Portfolio",
    description:
      "Template de portfolio para desarrolladores con blog integrado, sistema de temas y optimizado para SEO.",
    image: "/placeholder-project-6.jpg",
    tags: ["Astro", "MDX", "Tailwind CSS"],
    liveUrl: "https://example.com",
    githubUrl: "https://github.com",
    featured: false,
  },
];

const featuredProjects = projects.filter((p) => p.featured);
const otherProjects = projects.filter((p) => !p.featured);
---

<section id="projects" class="projects-section">
  <div class="projects-container">
    <!-- Section header -->
    <div class="section-header">
      <span class="section-tag">Proyectos</span>
      <h2 class="section-title">Trabajos destacados</h2>
      <p class="section-description">
        Una seleccion de proyectos en los que he trabajado, desde
        aplicaciones web hasta herramientas de productividad.
      </p>
    </div>

    <!-- Featured projects -->
    <div class="featured-grid">
      {featuredProjects.map((project) => (
        <div class="featured-card">
          <!-- Image placeholder -->
          <div class="project-image">
            <div class="image-overlay"></div>
            <div class="image-placeholder">
              <span class="placeholder-letter">{project.title.charAt(0)}</span>
            </div>
          </div>

          <!-- Content -->
          <div class="project-content">
            <h3 class="project-title">{project.title}</h3>
            <p class="project-description">{project.description}</p>

            <!-- Tags -->
            <div class="project-tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>

            <!-- Links -->
            <div class="project-links">
              <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
                <span class="icon-mask project-icon" style={`--icon-url: url('${CUSTOM_IMGS.github}')`} aria-hidden="true"></span>
                Codigo
              </a>
              <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                <span class="icon-mask project-icon" style={`--icon-url: url('${CUSTOM_IMGS.externalLink}')`} aria-hidden="true"></span>
                Demo
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Other projects - smaller cards -->
    <div class="other-grid">
      {otherProjects.map((project) => (
        <div class="other-card">
          <div class="other-header">
            <h4 class="other-title">{project.title}</h4>
            <div class="other-icons">
              <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" aria-label={`Ver codigo de ${project.title}`} class="icon-link">
                <span class="icon-mask project-icon" style={`--icon-url: url('${CUSTOM_IMGS.github}')`} aria-hidden="true"></span>
              </a>
              <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" aria-label={`Ver demo de ${project.title}`} class="icon-link">
                <span class="icon-mask project-icon" style={`--icon-url: url('${CUSTOM_IMGS.externalLink}')`} aria-hidden="true"></span>
              </a>
            </div>
          </div>
          <p class="other-description">{project.description}</p>
          <div class="other-tags">
            {project.tags.slice(0, 3).map((tag, index) => (
              <span class="tag-text">
                {tag}{index < 2 && ' · '}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  :root {
    --background: oklch(0.13 0.02 260);
    --foreground: oklch(0.95 0 0);
    --primary: oklch(0.65 0.2 180);
    --muted-foreground: oklch(0.65 0 0);
    --secondary: oklch(0.22 0.02 260);
    --border: oklch(0.28 0.02 260);
    --card: oklch(0.16 0.02 260);
  }

  .projects-section {
    padding: 6rem 0;
    position: relative;
  }

  .projects-container {
    max-width: 1152px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .projects-container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .projects-container {
      padding: 0 2rem;
    }
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-tag {
    color: var(--primary);
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .section-title {
    font-size: 1.875rem;
    font-weight: 700;
    margin-top: 1rem;
    margin-bottom: 1.5rem;
    color: var(--foreground);
  }

  @media (min-width: 640px) {
    .section-title {
      font-size: 2.25rem;
    }
  }

  .section-description {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--muted-foreground);
    font-size: 1.125rem;
  }

  .featured-grid {
    display: grid;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 1024px) {
    .featured-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .featured-card {
    border-radius: 1rem;
    background: rgba(38, 37, 45, 0.5);
    border: 1px solid rgba(49, 48, 56, 0.5);
    overflow: hidden;
    transition: border-color 0.3s;
  }

  .featured-card:hover {
    border-color: rgba(104, 208, 208, 0.5);
  }

  .project-image {
    aspect-ratio: 16 / 9;
    background: linear-gradient(to bottom right, var(--secondary), rgba(44, 43, 51, 0.5));
    position: relative;
    overflow: hidden;
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(38, 37, 45, 0.9), transparent);
  }

  .image-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-letter {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--primary);
    opacity: 0.2;
  }

  .project-content {
    padding: 1.5rem;
  }

  .project-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--foreground);
    transition: color 0.2s;
  }

  .featured-card:hover .project-title {
    color: var(--primary);
  }

  .project-description {
    color: var(--muted-foreground);
    font-size: 0.875rem;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tag {
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    background: rgba(44, 43, 51, 0.5);
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
  }

  .btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: all 0.2s;
    border: 1px solid transparent;
  }

  .btn-outline {
    border-color: rgba(49, 48, 56, 0.5);
    background: transparent;
    color: var(--foreground);
  }

  .btn-outline:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .btn-primary {
    background: var(--primary);
    color: var(--background);
  }

  .btn-primary:hover {
    background: oklch(0.6 0.18 180);
  }

  .icon-mask {
    --icon-url: none;
    display: block;
    width: 1rem;
    height: 1rem;
    background-color: currentColor;
    -webkit-mask: var(--icon-url) center / contain no-repeat;
    mask: var(--icon-url) center / contain no-repeat;
  }

  .other-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .other-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .other-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .other-card {
    padding: 1.25rem;
    border-radius: 0.75rem;
    background: rgba(38, 37, 45, 0.3);
    border: 1px solid rgba(49, 48, 56, 0.5);
    transition: border-color 0.2s;
  }

  .other-card:hover {
    border-color: rgba(104, 208, 208, 0.5);
  }

  .other-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .other-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--foreground);
    transition: color 0.2s;
  }

  .other-card:hover .other-title {
    color: var(--primary);
  }

  .other-icons {
    display: flex;
    gap: 0.5rem;
  }

  .icon-link {
    color: var(--muted-foreground);
    transition: color 0.2s;
  }

  .icon-link:hover {
    color: var(--primary);
  }

  .other-description {
    color: var(--muted-foreground);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .other-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .tag-text {
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }
</style>
