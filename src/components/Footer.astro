---
import {SOCIAL_NETWORKS} from '../constants/social-network.constants.ts';
import {CUSTOM_IMGS} from '../constants/custom-imgs.constants.ts';
import {HOST_URL} from "../constants/app.constants.ts";

const currentYear = new Date().getFullYear();
---

<footer class="footer">
    <div class="footer-container">
        <div class="footer-content">
            <!-- Logo and copyright -->
            <div class="footer-brand">
                <a href={HOST_URL} class="logo">
                    <img src={CUSTOM_IMGS.keycapBw} alt="Logo de Joel Tapia" class="logo-image" loading="lazy" />
                </a>
                <p class="copyright">
                    {currentYear} Joel Tapia. ✌️
                </p>
            </div>

            <!-- Social links -->
            <div class="social-links">
                <a href={SOCIAL_NETWORKS.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub"
                   class="social-link">
                    <span class="icon-mask social-icon" style={`--icon-url: url('${CUSTOM_IMGS.github}')`} aria-hidden="true"></span>
                </a>
                <a href={SOCIAL_NETWORKS.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
                   class="social-link">
                    <span class="icon-mask social-icon" style={`--icon-url: url('${CUSTOM_IMGS.linkedin}')`} aria-hidden="true"></span>
                </a>
                <a href={SOCIAL_NETWORKS.email} aria-label="Email" class="social-link">
                    <span class="icon-mask social-icon" style={`--icon-url: url('${CUSTOM_IMGS.email}')`} aria-hidden="true"></span>
                </a>
            </div>
        </div>
    </div>
</footer>

<style>
    :root {
        --background: oklch(0.13 0.02 260);
        --foreground: oklch(0.95 0 0);
        --primary: oklch(0.65 0.2 180);
        --muted-foreground: oklch(0.65 0 0);
        --border: oklch(0.28 0.02 260);
    }

    .footer {
        padding: 3rem 0;
        border-top: 1px solid rgba(49, 48, 56, 0.5);
    }

    .footer-container {
        max-width: 1152px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    @media (min-width: 640px) {
        .footer-container {
            padding: 0 1.5rem;
        }
    }

    @media (min-width: 1024px) {
        .footer-container {
            padding: 0 2rem;
        }
    }

    .footer-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
    }

    @media (min-width: 768px) {
        .footer-content {
            flex-direction: row;
        }
    }

    .footer-brand {
        text-align: center;
    }

    @media (min-width: 768px) {
        .footer-brand {
            text-align: left;
        }
    }

    .logo {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
    }

    .logo-image {
        width: 2.75rem;
        height: auto;
        display: block;
    }

    .bracket {
        color: var(--primary);
    }

    .copyright {
        font-size: 0.875rem;
        color: var(--muted-foreground);
        margin-top: 0.5rem;
    }

    .social-links {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .social-link {
        color: var(--muted-foreground);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s;
        text-decoration: none;
    }

    .icon-mask {
        --icon-url: none;
        display: block;
        width: 1.25rem;
        height: 1.25rem;
        background-color: currentColor;
        -webkit-mask: var(--icon-url) center / contain no-repeat;
        mask: var(--icon-url) center / contain no-repeat;
    }

    .social-link:hover {
        color: var(--primary);
    }

    .footer-bottom {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(49, 48, 56, 0.5);
        text-align: center;
    }

    .footer-text {
        font-size: 0.875rem;
        color: var(--muted-foreground);
    }

    .footer-link {
        color: var(--primary);
        text-decoration: none;
        transition: opacity 0.2s;
    }

    .footer-link:hover {
        text-decoration: underline;
    }
</style>

<script>
    // Smooth scroll for logo link
    const logo = document.querySelector('.footer .logo');
    logo?.addEventListener('click', (e) => {
        e.preventDefault();
        window.scrollTo({top: 0, behavior: 'smooth'});
    });
</script>
