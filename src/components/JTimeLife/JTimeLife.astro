---
const data = [{
    title: 'Registration',
    time: '12:30 - 1:00pm',
    description: `Get here on time, it's first come first serve. Be late, get turned away.`,
}, {
    title: 'Opening Ceremony',
    time: '2:30 - 4:00pm',
    description: `Get ready for an exciting event, this will kick off in amazing fashion with MOP & Busta Rhymes as an opening show.`,
}, {
    title: 'Main Event',
    time: '5:00 - 8:00pm',
    description: `This is where it all goes down. You will compete head to head with your friends and rivals. Get ready!`,
}, {
    title: 'Closing Ceremony',
    time: '8:30 - 9:30pm',
    description: `See who is the victor and who are the losers. The big stage is where the winners bask in their own glory.`,
}]
---
<div class='timeline-container'>
    <ul class='timeline'>
        {data.map((item) => (
                <li class='timeline-event' data-date={item.time}>
                    <h3 class='timeline-event__title'>{item.title}</h3>
                    <p class="time-event__time">{item.time}</p>
                    <p class='timeline-event__desc'>
                        {item.description}
                    </p>
                </li>
        ))}
    </ul>
</div>

<style>
    /* ===== VARIABLES ===== */
    :root {
        --color-bg: #f9fafb;
        --color-text: #1f2937;
        --color-muted: #374151;
        --color-accent: #2563eb;
        --color-accent-dark: #1e3a8a;
        --color-border: rgba(236, 0, 0, 0.1);
        --color-shadow: rgba(0, 0, 0, 0.05);

        --radius: 4px;
        --spacing: 50px;
        --line-thickness: 4px;
        --dot-size: 11px;
        --dot-ring: 4px;

        --font-title: 'Oswald', sans-serif;
        --font-body: 'Source Sans Pro', sans-serif;

        /* altura estimada de la navegación (se puede sobrescribir desde el sitio) */
        --nav-height: 64px;
    }

    /* ===== CONTENEDOR PRINCIPAL ===== */
    .timeline-container {
        background: var(--color-bg);
        /* compensar la nav fija mediante padding superior */
        padding-block-start: calc(var(--spacing) + var(--nav-height));
        padding-block-end: var(--spacing);
        text-align: center;
    }

    .timeline-title {
        letter-spacing: 2px;
        color: var(--color-text);
        font-weight: 500;
        font-size: 2.4em;
        margin-block-end: 1.5rem;
    }

    /* ===== TIMELINE ===== */
    .timeline {
        /* asegurar contexto posicionado y z-index bajo */
        position: relative;
        z-index: 0;

        list-style: none;
        margin: var(--spacing) auto;
        padding: var(--spacing);
        border-left: var(--line-thickness) solid var(--color-accent);
        border-radius: 0 var(--radius) var(--radius) 0;
        background: rgba(37, 99, 235, 0.03);
        color: var(--color-text);
        line-height: 1.6em;
        font-size: 1.05em;
        font-weight: 400;
        max-width: 55%;
        text-align: left;
        box-shadow: 0 2px 8px var(--color-shadow);
    }

    /* ===== EVENTOS ===== */
    .timeline-event {
        position: relative;
        border-bottom: 1px dashed var(--color-border);
        padding-bottom: calc(var(--spacing) / 2);
        margin-bottom: var(--spacing);
    }

    .timeline-event:last-of-type {
        border-bottom: none;
        padding-bottom: 0;
        margin-bottom: 0;
    }

    .time-event__time {
        font-weight: bolder;
    }

    /* Punto en la línea (pseudo-elemento) */
    .timeline-event::after {
        content: '';
        position: absolute;
        top: 5px;
        left: calc(
                (var(--spacing) + var(--line-thickness) + (var(--dot-size) * 0.35)) * -1
        );
        height: var(--dot-size);
        width: var(--dot-size);
        border-radius: 50%;
        background: #fff;
        box-shadow: 0 0 0 var(--dot-ring) var(--color-accent);
        /* asegurar que los puntos no aparezcan por encima de un nav con z-index bajo */
        z-index: 0;
    }

    /* ===== CONTENIDO DEL EVENTO ===== */
    .timeline-event__title {
        font-family: var(--font-title);
        font-weight: 600;
        font-size: 1.3em;
        color: var(--color-accent-dark);
        margin-bottom: 0.4em;
        letter-spacing: 1px;
    }

    .timeline-event__desc {
        color: var(--color-muted);
        margin: 0.3em 0;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
        .timeline {
            padding: 1.5rem;
            max-width: 90%;
        }

        .timeline-event::before {
            display: block;
            position: relative;
            left: 0;
            text-align: left;
            margin-bottom: 0.25em;
            color: var(--color-accent-dark);
            font-weight: 600;
        }

        .timeline-event::after {
            display: none;
        }
    }
</style>