---
import { METADATA } from '../constants/metadata.constants';
import { HOST_URL } from '../constants/app.constants';
import '../styles/global.css';
import Nav from './Nav/Nav.astro';

// ========= TYPES =========
interface LayoutProps {
  title?: string;
}

// ========= LOGIC =========
const { title } = Astro.props as LayoutProps;
const _title = title ? `${title} | Joel Tapia` : 'Joel Tapia';
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.png' />
    <meta name='generator' content={Astro.generator} />
    <!-- Open Graph -->
    <meta property='og:title' content={METADATA.tile} />
    <meta property='og:description' content={METADATA.description} />
    <meta property='og:url' content={METADATA.url} />
    <meta property='og:type' content={METADATA.type} />
    <meta property='og:image' content={METADATA.image} />
    <!-- canonical -->
    <link rel='canonical' href={HOST_URL} />

    <title>{_title}</title>
  </head>
  <body class="bg-pattern ">
    <div class='max-w-11/12 flex content-center border-2'>
      <slot />
    </div>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
