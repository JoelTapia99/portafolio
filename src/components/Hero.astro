---
import JAnchor from './JAnchor.astro';
import { LINK } from '../constants/link.constants';
---
<div class='w-screen h-screen'>
  <section id='hero' class='flex items-center justify-around h-[90vh] px-6'>
    <div class='hero-card'>
      <h1 class='hero-card-title'>
        &lt;h1&gt; Hola, soy Joel Tapia&lt;/h1&gt;
      </h1>
      <p class='hero-card-paragraph'>
        Tengo más de 3 años de experiencia en el campo de la programación.
      </p>
      <p class='hero-card-paragraph'>
        Disfruto trabajando en proyectos innovadores y desafiantes que me
        permiten aplicar y expandir mis conocimientos en el desarrollo de
        software.
      </p>
      <JAnchor link={LINK.CSV} text='Mi curriculum'/>
    </div>
    <img class="w-1/3 max-w-xs rounded-xl shadow-lg" src="assets/hero.svg" alt="imagen de programador" />
  </section>

  <a class="flex items-center justify-center gap-2 bg-violet-700 text-white text-lg font-semibold py-3 px-6 rounded-xl shadow-lg hover:bg-violet-800 transition-colors duration-200" href="#abilities">
    Habilidades e Información
    <img class="w-6 h-6" src="assets/icons/down.svg" alt="down icon" />
  </a>
</div>
